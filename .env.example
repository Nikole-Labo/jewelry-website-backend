# Copy this file to .env and set your real password (never commit .env).

SQLSERVER_HOST=localhost
# Default is 1433 when host has no instance name. Use your port from SQL Server Configuration Manager if different.
# Leave blank if using a named instance like .\\SQLEXPRESS (SQL Server Browser should be running).
SQLSERVER_PORT=1433
SQLSERVER_USER=sa
# Wrap in double quotes if the password contains # " or spaces.
SQLSERVER_PASSWORD=
SQLSERVER_DATABASE=JewelryDB
# Set to true for Azure / encrypted connections
SQLSERVER_ENCRYPT=false
# Leave unset or true for typical local dev with self-signed certs
SQLSERVER_TRUST_CERT=true

# Strong secret in production (signs JWTs)
JWT_SECRET=change_me_to_a_long_random_string

# If dbo.Users stores the credential under PasswordHash (or another name) instead of "password":
# USERS_PASSWORD_COLUMN=PasswordHash

# Optional: extra allowed CORS origins (comma-separated), e.g. another dev port or staging URL.
# CORS_ORIGINS=http://localhost:3001,https://my-app.example.com
# Local dev: any http://localhost:* and http://127.0.0.1:* is allowed when NODE_ENV is not production.
